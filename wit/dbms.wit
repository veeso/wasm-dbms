package wasm-dbms:dbms;

interface types {
    /// Subset of `wasm_dbms_api::Value` exposed across the WIT boundary.
    ///
    /// Variants without a stable WIT primitive (Decimal, Date, DateTime, Json,
    /// Uuid, Custom) are encoded as their canonical string representation;
    /// the host or guest is responsible for parsing them back into the typed
    /// `Value`.
    variant value {
        bool-val(bool),
        u8-val(u8),
        u16-val(u16),
        u32-val(u32),
        u64-val(u64),
        i8-val(s8),
        i16-val(s16),
        i32-val(s32),
        i64-val(s64),
        text-val(string),
        blob-val(list<u8>),
        decimal-val(string),
        date-val(string),
        datetime-val(string),
        json-val(string),
        uuid-val(string),
        custom-val(custom-value),
        null-val,
    }

    record custom-value {
        type-tag: string,
        encoded: list<u8>,
        display: string,
    }

    record column-value {
        name: string,
        value: value,
    }
    type row = list<column-value>;

    enum order-direction { asc, desc }

    record order-key {
        column: string,
        direction: order-direction,
    }

    /// Mirrors `wasm_dbms_api::Query`. Structured filters (`Filter`,
    /// `Filter` for `having`, and per-join expressions) are passed as JSON
    /// strings produced by `serde_json::to_string` so the WIT surface stays
    /// flat; the guest deserialises them back into `Filter` before running
    /// the query.
    record query {
        /// `Filter` expression serialised as JSON (`WHERE` clause).
        filter: option<string>,
        /// Columns the result must be deduplicated on.
        distinct-by: list<string>,
        /// Foreign-key relations to load eagerly.
        eager-relations: list<string>,
        /// `Join` clauses serialised as JSON.
        joins: list<string>,
        /// `GROUP BY` columns.
        group-by: list<string>,
        /// `HAVING` `Filter` serialised as JSON. References aggregate outputs
        /// by their synthetic `agg{N}` names.
        having: option<string>,
        /// Multi-key ordering.
        order-by: list<order-key>,
        limit: option<u64>,
        offset: option<u64>,
    }

    /// Controls foreign-key handling on `delete`.
    enum delete-behavior { restrict, cascade }

    /// Aggregate function to compute over a group.
    variant aggregate-function {
        /// `COUNT(*)` when the inner is empty, otherwise `COUNT(col)`.
        count(option<string>),
        sum(string),
        avg(string),
        min(string),
        max(string),
    }

    /// Result of one aggregate function evaluated against a group.
    variant aggregated-value {
        count(u64),
        sum(value),
        avg(value),
        min(value),
        max(value),
    }

    /// One row of aggregated output.
    record aggregated-row {
        /// Values of the `GROUP BY` columns identifying this group, in
        /// declared order. Empty when the query had no `GROUP BY`.
        group-keys: list<value>,
        /// One entry per `aggregate-function` passed to `aggregate`, in the
        /// same order.
        values: list<aggregated-value>,
    }

    type transaction-id = u64;

    // ── Schema migrations ───────────────────────────────────────────────
    //
    // Mirrors `wasm_dbms_api::dbms::migration` and the snapshot types in
    // `wasm_dbms_api::dbms::table::schema::snapshot`. Used by the
    // `has-drift`, `pending-migrations`, and `migrate` entry points.

    /// On-disk wire layout descriptor for a custom-typed column.
    variant wire-size {
        fixed(u32),
        length-prefixed,
    }

    /// User-defined custom data type identifier + wire layout.
    record custom-data-type-snapshot {
        tag: string,
        wire-size: wire-size,
    }

    /// Stable, tag-keyed encoding of a column data type. Discriminants are
    /// part of the on-disk format and must not be reused or reordered.
    variant data-type-snapshot {
        int8,
        int16,
        int32,
        int64,
        uint8,
        uint16,
        uint32,
        uint64,
        float32,
        float64,
        decimal,
        boolean,
        date,
        datetime,
        blob,
        text,
        uuid,
        json,
        custom(custom-data-type-snapshot),
    }

    /// `ON DELETE` referential action.
    enum on-delete-snapshot { restrict, cascade }

    /// Foreign-key reference attached to a column.
    record foreign-key-snapshot {
        table: string,
        column: string,
        on-delete: on-delete-snapshot,
    }

    /// Snapshot of a single column definition.
    record column-snapshot {
        name: string,
        data-type: data-type-snapshot,
        nullable: bool,
        auto-increment: bool,
        unique: bool,
        primary-key: bool,
        foreign-key: option<foreign-key-snapshot>,
        default: option<value>,
    }

    /// Snapshot of a secondary index.
    record index-snapshot {
        columns: list<string>,
        unique: bool,
    }

    /// Snapshot of a complete table schema.
    record table-schema-snapshot {
        version: u8,
        name: string,
        primary-key: string,
        alignment: u32,
        columns: list<column-snapshot>,
        indexes: list<index-snapshot>,
    }

    /// Foreign-key delta inside `column-changes`. Mirrors the inner
    /// `Option<ForeignKeySnapshot>` of `ColumnChanges::foreign_key`:
    /// `none` = no change, `some(drop)` = drop, `some(set(fk))` = add/replace.
    variant foreign-key-change {
        drop,
        set(foreign-key-snapshot),
    }

    /// Constraint-flag deltas for `migration-op::alter-column`.
    record column-changes {
        nullable: option<bool>,
        unique: option<bool>,
        auto-increment: option<bool>,
        primary-key: option<bool>,
        foreign-key: option<foreign-key-change>,
    }

    /// Single atomic migration step produced by the planner.
    variant migration-op {
        create-table(create-table-op),
        drop-table(string),
        add-column(add-column-op),
        drop-column(drop-column-op),
        rename-column(rename-column-op),
        alter-column(alter-column-op),
        widen-column(type-change-op),
        transform-column(type-change-op),
        add-index(index-op),
        drop-index(index-op),
    }

    record create-table-op {
        name: string,
        schema: table-schema-snapshot,
    }

    record add-column-op {
        table: string,
        column: column-snapshot,
    }

    record drop-column-op {
        table: string,
        column: string,
    }

    record rename-column-op {
        table: string,
        old: string,
        new: string,
    }

    record alter-column-op {
        table: string,
        column: string,
        changes: column-changes,
    }

    record type-change-op {
        table: string,
        column: string,
        old-type: data-type-snapshot,
        new-type: data-type-snapshot,
    }

    record index-op {
        table: string,
        index: index-snapshot,
    }

    /// Caller policy gating destructive ops.
    record migration-policy {
        allow-destructive: bool,
    }

    /// Mirrors `wasm_dbms_api::DbmsError` and its inner variants. Detailed
    /// messages preserve the source `QueryError` / `TableError` string for
    /// host-side diagnostics.
    variant dbms-error {
        /// Table not registered in the schema.
        table-not-found(string),
        /// Primary-key uniqueness violated.
        primary-key-conflict,
        /// `#[unique]` column collision.
        unique-constraint-violation(string),
        /// Foreign key references a non-existent parent row.
        broken-foreign-key-reference(string),
        /// `Restrict` delete blocked by an existing foreign-key reference.
        foreign-key-constraint-violation(string),
        /// Unknown column referenced by the query.
        unknown-column(string),
        /// Required (non-nullable) column missing on insert.
        missing-non-nullable-field(string),
        /// Active transaction not found or already closed.
        transaction-not-found,
        /// Query is syntactically or semantically invalid.
        invalid-query(string),
        /// Joins used with a typed select path.
        join-inside-typed-select,
        /// `GROUP BY` / `HAVING` set on a non-aggregate select path.
        aggregate-clause-in-select,
        /// Generic constraint violation.
        constraint-violation(string),
        /// Sanitizer rejected a value.
        sanitization-error(string),
        /// Validator rejected a value.
        validation-error(string),
        /// Underlying memory error.
        memory-error(string),
        /// Schema migration error (drift, incompatible type, missing default, ...).
        migration-error(string),
        /// Generic catch-all (internal / unexpected condition).
        internal-error(string),
    }
}

interface database {
    use types.{
        row,
        query,
        transaction-id,
        dbms-error,
        delete-behavior,
        aggregate-function,
        aggregated-row,
        migration-op,
        migration-policy,
    };

    /// Runs a `SELECT` against `table`, returning raw rows.
    select: func(table: string, query: query) -> result<list<row>, dbms-error>;

    /// Runs an aggregate query for `table`, computing each
    /// `aggregate-function` per group defined by `query.group-by`.
    aggregate: func(
        table: string,
        query: query,
        aggregates: list<aggregate-function>,
    ) -> result<list<aggregated-row>, dbms-error>;

    /// Inserts a row built from named column values.
    insert: func(table: string, values: row, tx: option<transaction-id>) -> result<_, dbms-error>;

    /// Updates rows matching `filter` (JSON-serialised `Filter`) with the
    /// supplied column values.
    update: func(
        table: string,
        values: row,
        filter: option<string>,
        tx: option<transaction-id>,
    ) -> result<u64, dbms-error>;

    /// Deletes rows matching `filter`. `behavior` controls foreign-key
    /// handling (`restrict` aborts on referenced rows; `cascade` deletes
    /// referencing rows recursively).
    delete: func(
        table: string,
        behavior: delete-behavior,
        filter: option<string>,
        tx: option<transaction-id>,
    ) -> result<u64, dbms-error>;

    begin-transaction: func() -> result<transaction-id, dbms-error>;
    commit: func(tx: transaction-id) -> result<_, dbms-error>;
    rollback: func(tx: transaction-id) -> result<_, dbms-error>;

    /// Returns `true` iff the compiled schema differs from the snapshots
    /// persisted in stable memory. Cached on the DBMS context after the
    /// first call.
    has-drift: func() -> result<bool, dbms-error>;

    /// Returns the migration ops needed to bring the on-disk schema in line
    /// with the compiled schema. Does not apply anything.
    pending-migrations: func() -> result<list<migration-op>, dbms-error>;

    /// Plans, validates, sorts, and applies the diff atomically. On success
    /// the drift flag is cleared; on failure the journal rolls back and the
    /// flag stays set.
    migrate: func(policy: migration-policy) -> result<_, dbms-error>;
}

world dbms {
    export database;
}
